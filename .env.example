AIRFLOW_UID=197609

# minio
MINIO_ENDPOINT = 'localhost:9000'
MINIO_ACCESS_KEY = 'ton access key'
MINIO_SECRET_KEY = 'ton secret key'
MINIO_BUCKET = 'ton bucket'
EMBEDDING_MODEL = 'sentence-transformers/all-MiniLM-L6-v2'

# Ollama
OLLAMA_BASE_URL='http://localhost:11434'
OLLAMA_MODEL_NAME='mistral-large-3:675b-cloud'
# OLLAMA_MODEL_NAME='gpt-oss:20b-cloud'
RAGAS_MODEL_NAME='mistral-large-3:675b-cloud'
DEEP_EVAL_MODEL_NAME='deepseek-v3.1:671b-cloud'

# Génération
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2048
DEFAULT_TEMPLATE='default' #detailed

# Base de données vectorielles
QDRANT_HOST = 'localhost'
QDRANT_PORT = 6333
QDRANT_COLLECTION = 'documents'

# Chunking
CHUNK_SIZE= 500
CHUNK_OVERLAP= 50

# Kafka
KAFKA_BOOTSTRAP_SERVERS = 'localhost:9092'
KAFKA_TOPIC = 'minio-events'
ENABLE_KAFKA_CONSUMER = true

# MongoDB
# Dans ton fichier de config (ex: .env ou config.py)
MONGODB_URL = "tu mongodb url"
MONGODB_HOST="ton host"
MONGODB_PORT=27017
MONGODB_USER='ton user'
MONGODB_PASSWORD='ton password'
MONGODB_AUTH_SOURCE="ton auth source"
MONGODB_DB_NAME = "ta db"
CONTEXT_MAX_MESSAGES = 6
CONTEXT_MAX_CHARS = 8000

# ── Application ───────────────────────────────────────────────────────────
ENVIRONMENT = "development"
SECRET_KEY = "ton secret key"
TOKEN_EXPIRE_HOURS = 24
CORS_ORIGINS = ["*"]