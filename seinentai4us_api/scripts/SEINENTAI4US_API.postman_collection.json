{
  "info": {
    "name": "SEINENTAI4US API",
    "description": "Collection complète pour l'API RAG SEINENTAI4US",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token",    "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Authentification",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@seinentai.jp\",\n  \"password\": \"MonMotDePasse123\",\n  \"full_name\": \"Tanaka Yuki\"\n}"
            },
            "description": "Crée un nouveau compte utilisateur."
          }
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    console.log('Token sauvegardé :', json.access_token.substring(0,20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@seinentai.jp\",\n  \"password\": \"MonMotDePasse123\"\n}"
            },
            "description": "Connecte l'utilisateur. Le token est automatiquement stocké dans {{token}}."
          }
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/auth/me" },
            "description": "Retourne le profil de l'utilisateur connecté."
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/auth/logout" },
            "description": "Révoque le token courant."
          }
        }
      ]
    },
    {
      "name": "📄 Documents",
      "item": [
        {
          "name": "GET /documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/documents" },
            "description": "Liste tous les documents dans MinIO avec leur statut d'indexation."
          }
        },
        {
          "name": "POST /documents/upload",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/documents/upload" },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "description": "Sélectionner un fichier PDF"
                }
              ]
            },
            "description": "Upload un PDF vers MinIO et déclenche l'indexation en arrière-plan."
          }
        },
        {
          "name": "GET /documents/{filename}/status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/documents/mon_document.pdf/status" },
            "description": "Vérifie le statut d'indexation : indexed | pending | not_found | error"
          }
        },
        {
          "name": "POST /documents/reindex",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/documents/reindex" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"force\": false,\n  \"filenames\": null\n}"
            },
            "description": "Réindexe tous les documents (ou une liste spécifique). force=true pour réindexer même les déjà indexés."
          }
        },
        {
          "name": "DELETE /documents/{filename}",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/documents/mon_document.pdf" },
            "description": "Supprime le document de MinIO ET tous ses chunks de Qdrant."
          }
        }
      ]
    },
    {
      "name": "🔍 Recherche",
      "item": [
        {
          "name": "POST /search (sémantique)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/search" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Quelles sont les activités du groupe des jeunes ?\",\n  \"limit\": 5,\n  \"score_threshold\": 0.2,\n  \"filename_filter\": null\n}"
            },
            "description": "Recherche sémantique par similarité de vecteurs denses."
          }
        },
        {
          "name": "GET /search/hybrid",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/search/hybrid?q=valeurs+seinentai&limit=5&score_threshold=0.0",
              "query": [
                { "key": "q",               "value": "valeurs seinentai" },
                { "key": "limit",           "value": "5" },
                { "key": "score_threshold", "value": "0.0" }
              ]
            },
            "description": "Recherche hybride BM25 + embeddings denses."
          }
        },
        {
          "name": "GET /search/rerank",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/search/rerank?q=activités+culturelles&boost_field=filename&boost_value=programme.pdf&limit=5",
              "query": [
                { "key": "q",           "value": "activités culturelles" },
                { "key": "boost_field", "value": "filename" },
                { "key": "boost_value", "value": "programme.pdf" },
                { "key": "limit",       "value": "5" }
              ]
            },
            "description": "Recherche avec re-ranking : les résultats correspondant au boost_field/boost_value sont remontés (×1.5)."
          }
        }
      ]
    },
    {
      "name": "💬 Chat",
      "item": [
        {
          "name": "POST /chat/new (direct)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.session_id) {",
                  "    pm.collectionVariables.set('session_id', json.session_id);",
                  "    console.log('Session ID :', json.session_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/chat/new" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Quelles sont les valeurs fondamentales du groupe SEINENTAI ?\",\n  \"temperature\": 0.7,\n  \"stream\": false,\n  \"search_limit\": 5,\n  \"score_threshold\": 0.0\n}"
            },
            "description": "Nouveau chat RAG — réponse JSON directe (stream=false). Le session_id est sauvegardé automatiquement."
          }
        },
        {
          "name": "POST /chat/new (streaming SSE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "text/event-stream" }
            ],
            "url": { "raw": "{{base_url}}/chat/new" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Parle-moi des activités du groupe.\",\n  \"temperature\": 0.7,\n  \"stream\": true\n}"
            },
            "description": "Nouveau chat avec streaming SSE. Chaque ligne data: contient un JSON avec type=token|start|done."
          }
        },
        {
          "name": "POST /chat/{session_id} (continuer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "text/event-stream" }
            ],
            "url": { "raw": "{{base_url}}/chat/{{session_id}}" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"message\": \"Peux-tu me donner plus de détails ?\",\n  \"stream\": true\n}"
            },
            "description": "Continue une session existante avec contexte conversationnel. Retourne un flux SSE."
          }
        },
        {
          "name": "GET /chat/history",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/chat/history" },
            "description": "Liste toutes les sessions de chat de l'utilisateur connecté."
          }
        },
        {
          "name": "GET /chat/sessions/{session_id}",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/chat/sessions/{{session_id}}" },
            "description": "Retourne l'historique complet d'une session (tous les messages user + assistant)."
          }
        }
      ]
    },
    {
      "name": "🏥 Système",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health" },
            "description": "Vérifie la santé de tous les services : Qdrant, MinIO, Ollama, Kafka."
          }
        },
        {
          "name": "GET / (racine)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/" },
            "description": "Informations générales sur l'API."
          }
        }
      ]
    }
  ]
}
